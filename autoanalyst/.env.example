# Telegram API credentials (from https://my.telegram.org)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Telegram peer ID -- the other person's user ID in your 1-2-1 chat
# Run `python autoanalyst.py --list-chats` to discover this
TELEGRAM_PEER_ID=

# Anthropic API key (from https://console.anthropic.com)
ANTHROPIC_API_KEY=

# X API Bearer Token (Basic tier)
# Optional -- falls back to fxtwitter if not set
X_BEARER_TOKEN=

# Claude model to use (optional, default: claude-sonnet-4-20250514)
CLAUDE_MODEL=claude-sonnet-4-20250514

# Set to true to also analyze your own tweet links
ANALYZE_OWN=false

# Analysis backend: "claude" or "perplexity" (default: claude)
ANALYSIS_BACKEND=claude

# Perplexity API key (required if ANALYSIS_BACKEND=perplexity)
PERPLEXITY_API_KEY=

# Perplexity model (optional, default: sonar-pro)
PERPLEXITY_MODEL=sonar-pro

# OpenAI API key (for Whisper video transcription)
# Optional -- without it, video transcription is skipped
OPENAI_API_KEY=
