# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=

# Comma-separated list of allowed Telegram user IDs
ALLOWED_USER_IDS=

# Anthropic API key (from https://console.anthropic.com)
# Optional -- leave empty to use Claude Max subscription
ANTHROPIC_API_KEY=

# Enable dangerous mode -- allows Claude to execute arbitrary commands
# Optional, default: false
DANGEROUS_MODE=false

# Response mode: "streaming" (live-updating) or "wait" (send when complete)
# Optional, default: streaming
STREAMING_MODE=streaming

# Custom bot name used in system prompt
# Optional, default: Claudegram
BOT_NAME=
